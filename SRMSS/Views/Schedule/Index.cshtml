@model IEnumerable<SRMSS.Models.Schedule>

@{
    ViewData["Title"] = "Schedule Management";
}

<div class="container-fluid mt-3">

    <div class="card shadow-sm">

        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">

            <h4 class="mb-0">📅 Schedule Management</h4>

            <a asp-action="Create" class="btn btn-light">
                ➕ Add Schedule
            </a>

        </div>

        <form asp-action="Index" method="get" class="mb-3">

            <div class="input-group">

                <input type="text"
                       name="searchString"
                       class="form-control"
                       placeholder="Search Route / Bus / Driver" />

                <button type="submit"
                        class="btn btn-primary">
                    Search
                </button>

            </div>

        </form>

        <div class="card-body">

            <table class="table table-bordered table-striped table-hover">

                <thead class="table-dark">

                    <tr>
                        <th>ID</th>
                        <th>Route Code</th>
                        <th>Bus Number</th>
                        <th>Driver Name</th>
                        <th>Date</th>
                        <th>Departure</th>
                        <th>Arrival</th>
                        <th>Trip Type</th>
                        <th>Status</th>
                        <th>Remarks</th>
                        <th width="180">Action</th>
                    </tr>

                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        <tr>

                            <td>@item.ScheduleID</td>

                            <td>@item.RouteCode</td>

                            <td>@item.BusNumber</td>

                            <td>@item.DriverName</td>

                            <td>@item.ScheduleDate.ToShortDateString()</td>

                            <td>@item.DepartureTime</td>

                            <td>@item.ArrivalTime</td>

                            <td>@item.TripType</td>

                            <td>

                                @if (item.TripStatus == "Completed")
                                {
                                    <span class="badge bg-success">
                                        @item.TripStatus
                                    </span>
                                }
                                else if (item.TripStatus == "Delayed")
                                {
                                    <span class="badge bg-warning text-dark">
                                        @item.TripStatus
                                    </span>
                                }
                                else if (item.TripStatus == "Cancelled")
                                {
                                    <span class="badge bg-danger">
                                        @item.TripStatus
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">
                                        @item.TripStatus
                                    </span>
                                }

                            </td>

                            <td>@item.Remarks</td>

                            <td>

                                <a asp-action="Edit"
                                   asp-route-id="@item.ScheduleID"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                               

                                <a asp-action="Delete"
                                   asp-route-id="@item.ScheduleID"
                                   class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</div>