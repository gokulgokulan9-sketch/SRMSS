@model SRMSS.Models.Schedule

@{
    ViewData["Title"] = "Delete Schedule";
}

<div class="card shadow border-danger">

    <div class="card-header bg-danger text-white">
        <h3>🗑 Delete Schedule</h3>
    </div>

    <div class="card-body">

        <h4 class="text-danger">
            Are you sure you want to delete this schedule?
        </h4>

        <hr />

        <dl class="row">

            <dt class="col-sm-3">Route Code</dt>
            <dd class="col-sm-9">@Model.RouteCode</dd>

            <dt class="col-sm-3">Bus Number</dt>
            <dd class="col-sm-9">@Model.BusNumber</dd>

            <dt class="col-sm-3">Driver Name</dt>
            <dd class="col-sm-9">@Model.DriverName</dd>

            <dt class="col-sm-3">Schedule Date</dt>
            <dd class="col-sm-9">@Model.ScheduleDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Departure Time</dt>
            <dd class="col-sm-9">@Model.DepartureTime</dd>

            <dt class="col-sm-3">Arrival Time</dt>
            <dd class="col-sm-9">@Model.ArrivalTime</dd>

            <dt class="col-sm-3">Trip Type</dt>
            <dd class="col-sm-9">@Model.TripType</dd>

            <dt class="col-sm-3">Trip Status</dt>
            <dd class="col-sm-9">@Model.TripStatus</dd>

            <dt class="col-sm-3">Remarks</dt>
            <dd class="col-sm-9">@Model.Remarks</dd>

        </dl>

        <form asp-action="Delete">

            <input type="hidden" asp-for="ScheduleID" />

            <button type="submit" class="btn btn-danger">
                Confirm Delete
            </button>

            <a asp-action="Index" class="btn btn-secondary">
                Cancel
            </a>

        </form>

    </div>

</div>