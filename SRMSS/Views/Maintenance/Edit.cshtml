@model SRMSS.Models.MaintenanceLog

<h2>Add Maintenance</h2>

<form asp-action="Edit">

    <input type="hidden" asp-for="MaintenanceID" />

   

    <div class="mb-2">
        <label>Bus Number</label>
        <input asp-for="BusNumber" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Maintenance Date</label>
        <input asp-for="MaintenanceDate" type="date" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Maintenance Type</label>
        <input asp-for="MaintenanceType" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Service Cost</label>
        <input asp-for="ServiceCost" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Next Service Date</label>
        <input asp-for="NextServiceDate" type="date" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Mechanic Name</label>
        <input asp-for="MechanicName" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Status</label>
        <input asp-for="Status" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Remarks</label>
        <input asp-for="Remarks" class="form-control" />
    </div>

    <button class="btn btn-warning">
        Update
    </button>

</form>