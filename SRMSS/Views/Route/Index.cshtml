@model IEnumerable<SRMSS.Models.RouteInfo>

@{
    ViewData["Title"] = "Route Management";
}

<div class="container mt-4">

    <h2 class="text-center">
        Route Management
    </h2>

    <hr />
    <form method="get">
        <div class="row mb-3">

            <div class="col-md-4">
                <input type="text"
                       name="search"
                       class="form-control"
                       placeholder="Search Route..." />
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary">
                    Search
                </button>
            </div>

        </div>
    </form>

    <a href="/Route/Create"
       class="btn btn-primary mb-3">
        Add New Route
    </a>

    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>Route Code</th>
                <th>Route Name</th>
                <th>Start Point</th>
                <th>End Point</th>
                <th>Stops</th>
                <th>Total Distance</th>
                <th>Assigned Bus</th>
                <th>Assigned Driver</th>
                <th>Route Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.RouteCode</td>
                    <td>@item.RouteName</td>
                    <td>@item.StartPoint</td>
                    <td>@item.EndPoint</td>
                    <td>@item.Stops</td>
                    <td>@item.TotalDistance</td>
                    <td>@item.AssignedBus</td>
                    <td>@item.AssignedDriver</td>
                    <td>@item.RouteStatus</td>
                    <td>
                        <a href="/Route/Edit/@item.RouteID"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>

                        <a href="/Route/Delete/@item.RouteID"
                           class="btn btn-danger btn-sm"
                           onclick="return confirm('Are you sure want to delete this route?');">
                            Delete
                        </a>
                    </td>
                </tr>
            }

        </tbody>

    </table
    <div class="mt-3">

    @for (int i = 1; i <= ViewBag.TotalPages; i++)
    {
        <a href="/Route?page=@i"
           class="btn btn-primary btn-sm">
            @i
        </a>
    }

</div>

</div>