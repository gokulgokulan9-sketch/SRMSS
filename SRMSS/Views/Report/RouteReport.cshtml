@model IEnumerable<SRMSS.Models.RouteInfo>

@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        margin: 20px;
        font-size: 12px;
    }

    h1, h2, h3, p {
        text-align: center;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #0d6efd;
        color: white;
        padding: 8px;
        text-align: center;
    }

    td {
        border: 1px solid #ddd;
        padding: 6px;
        text-align: center;
    }

    .footer {
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary"> ← Back </a>

    <a asp-action="RouteReportPDF" class="btn btn-danger">
        Download PDF
    </a>

</div>

<div class="text-center mb-4">
    <h1 style="color:#0d6efd;"> SMART ROUTE MANAGEMENT SYSTEM </h1>

    <h3>
        Route Management Report
    </h3>

    <p>
        Generated Date :
        @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
    </p>

    <hr />

</div>

<div> Total Routes : <strong>@Model.Count()</strong> </div>

<br />

<table>
    <thead> <tr> <th>Route ID</th> <th>Route Code</th> <th>Route Name</th> <th>Start Point</th> <th>End Point</th> <th>Stops</th> <th>Total Distance</th> <th>Assigned Bus</th> <th>Assigned Driver</th> <th>Status</th> </tr> </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.RouteID</td>
                <td>@item.RouteCode</td>
                <td>@item.RouteName</td>
                <td>@item.StartPoint</td>
                <td>@item.EndPoint</td>
                <td>@item.Stops</td>
                <td>@item.TotalDistance</td>
                <td>@item.AssignedBus</td>
                <td>@item.AssignedDriver</td>
                <td>@item.RouteStatus</td>
            </tr>
        }
    </tbody>

</table>

<div class="footer">
    <hr />

    <p>
        Generated by SRMSS Reporting Module
    </p>

    <p>
        © 2026 Smart Route Management System
    </p>

</div>