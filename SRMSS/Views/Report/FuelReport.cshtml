@model IEnumerable<SRMSS.Models.FuelLog>

@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        margin: 20px;
        font-size: 12px;
    }

    h1, h2, h3, p {
        text-align: center;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #0d6efd;
        color: white;
        padding: 8px;
        text-align: center;
    }

    td {
        border: 1px solid #ddd;
        padding: 6px;
        text-align: center;
    }

    .footer {
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary"> ← Back </a>

    <a asp-action="FuelReportPDF" class="btn btn-danger">
        Download PDF
    </a>

</div>

<div class="text-center mb-4">
    <h1 style="color:#0d6efd;"> SMART ROUTE MANAGEMENT SYSTEM </h1>

    <h3>
        Fuel Management Report
    </h3>

    <p>
        Generated Date :
        @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
    </p>

    <hr />

</div>

<div> Total Fuel Records : <strong>@Model.Count()</strong> </div>

<br />

<table>
    <thead> <tr> <th>Fuel Log ID</th> <th>Bus Number</th> <th>Route Code</th> <th>Fuel Quantity (L)</th> <th>Fuel Cost</th> <th>Fuel Station</th> </tr> </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.FuelLogID</td>
                <td>@item.BusNumber</td>
                <td>@item.RouteCode</td>
                <td>@item.FuelQuantity</td>
                <td>@item.FuelCost</td>
                <td>@item.FuelStation</td>
            </tr>
        }
    </tbody>

</table>

<div class="footer">
    <hr />

    <p>
        Generated by SRMSS Reporting Module
    </p>

    <p>
        © 2026 Smart Route Management System
    </p>

</div>