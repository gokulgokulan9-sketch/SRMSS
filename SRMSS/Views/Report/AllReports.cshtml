@model SRMSS.Models.AllReportsViewModel

@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        margin: 20px;
        font-size: 12px;
    }

    h1, h2, h3, p {
        text-align: center;
    }

    table {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 20px;
    }

    th {
        background-color: #0d6efd;
        color: white;
        padding: 8px;
        text-align: center;
    }

    td {
        border: 1px solid #ddd;
        padding: 6px;
        text-align: center;
    }

    .section-title {
        background: #f2f2f2;
        padding: 8px;
        border-left: 5px solid #0d6efd;
    }

    .footer {
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary"> ← Back </a>

    <a asp-action="AllReportsPDF" class="btn btn-danger">
        Download PDF
    </a>

</div>

<h1 style="color:#0d6efd;"> SMART ROUTE MANAGEMENT SYSTEM </h1>

<h2>Complete System Report</h2>

<p> Generated Date : @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt") </p>

<hr />

<h3 class="section-title"> Bus Report (Total: @Model.Buses.Count()) </h3>

<table>
    <tr> <th>Bus Number</th> <th>Bus Type</th> </tr>

    @foreach (var item in Model.Buses)
    {
        <tr>
            <td>@item.BusNumber</td>
            <td>@item.BusType</td>
        </tr>
    }

</table>

<h3 class="section-title"> Driver Report (Total: @Model.Drivers.Count()) </h3>

<table>
    <tr> <th>Driver Name</th> <th>Phone Number</th> </tr>

    @foreach (var item in Model.Drivers)
    {
        <tr>
            <td>@item.DriverName</td>
            <td>@item.PhoneNumber</td>
        </tr>
    }

</table>

<h3 class="section-title"> Route Report (Total: @Model.Routes.Count()) </h3>

<table>
    <tr> <th>Route Code</th> <th>Start Point</th> <th>End Point</th> </tr>

    @foreach (var item in Model.Routes)
    {
        <tr>
            <td>@item.RouteCode</td>
            <td>@item.StartPoint</td>
            <td>@item.EndPoint</td>
        </tr>
    }

</table>

<h3 class="section-title"> Schedule Report (Total: @Model.Schedules.Count()) </h3>

<table>
    <tr> <th>Route</th> <th>Bus</th> <th>Driver</th> </tr>

    @foreach (var item in Model.Schedules)
    {
        <tr>
            <td>@item.RouteCode</td>
            <td>@item.BusNumber</td>
            <td>@item.DriverName</td>
        </tr>
    }

</table>

<h3 class="section-title"> Fuel Report (Total: @Model.FuelLogs.Count()) </h3>

<table>
    <tr> <th>Bus Number</th> <th>Fuel Quantity</th> <th>Fuel Cost</th> </tr>

    @foreach (var item in Model.FuelLogs)
    {
        <tr>
            <td>@item.BusNumber</td>
            <td>@item.FuelQuantity</td>
            <td>@item.FuelCost</td>
        </tr>
    }

</table>

<h3 class="section-title"> Maintenance Report (Total: @Model.MaintenanceLogs.Count()) </h3>

<table>
    <tr> <th>Bus Number</th> <th>Maintenance Type</th> <th>Service Cost</th> </tr>

    @foreach (var item in Model.MaintenanceLogs)
    {
        <tr>
            <td>@item.BusNumber</td>
            <td>@item.MaintenanceType</td>
            <td>@item.ServiceCost</td>
        </tr>
    }

</table>

<h3 class="section-title"> User Report (Total: @Model.Users.Count()) </h3>

<table>
    <tr> <th>Full Name</th> <th>Role</th> </tr>

    @foreach (var item in Model.Users)
    {
        <tr>
            <td>@item.FullName</td>
            <td>@item.Role</td>
        </tr>
    }

</table>

<div class="footer">
    <hr />

    <p>
        Generated by SRMSS Reporting Module
    </p>

    <p>
        © 2026 Smart Route Management System
    </p>

</div>