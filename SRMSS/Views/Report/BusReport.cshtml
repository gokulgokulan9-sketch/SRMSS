@model IEnumerable<SRMSS.Models.Bus>

<style>
    body {
        font-family: Arial;
        margin: 20px;
    }

    h1, h2, h3, p {
        text-align: center;
    }

    table {
        width: 100%;
    }

    th {
        background: #0d6efd;
        color: white;
        text-align: center;
    }

    td {
        text-align: center;
    }
</style>
@{
    Layout = null;
}


<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary">
        ← Back
    </a>

    <a asp-action="BusReportPDF" class="btn btn-danger">
        Download PDF
    </a>
</div>

<div class="text-center mb-4">
    <h1 style="color:#0d6efd;">
        SMART ROUTE MANAGEMENT SYSTEM
    </h1>
    <div style="width:95%; margin:auto;">
    <h3>
        Bus Management Report
    </h3>

    <p>
        Generated Date :
        @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
    </p>

    <hr />
</div>
<div class="alert alert-info">
    Total Buses :
    <strong>@Model.Count()</strong>
</div>

<table class="table table-bordered table-striped">
    <thead style="background-color:#0d6efd;color:white;">

    <thead class="table-dark">
        <tr>
            <th>Vehicle ID</th>
            <th>Bus Number</th>
            <th>Bus Model</th>
            <th>Bus Type</th>
            <th>Seating Capacity</th>
            <th>Mileage</th>
            <th>Fuel Type</th>
            <th>Purchase Date</th>
            <th>Maintenance Status</th>
            <th>Availability Status</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>
                <td>@item.VehicleID</td>
                <td>@item.BusNumber</td>
                <td>@item.BusModel</td>
                <td>@item.BusType</td>
                <td>@item.SeatingCapacity</td>
                <td>@item.Mileage</td>
                <td>@item.FuelType</td>
                <td>@item.PurchaseDate.ToString("dd/MM/yyyy")</td>
                <td>@item.MaintenanceStatus</td>
                <td>@item.AvailabilityStatus</td>
            </tr>
        }

    </tbody>

</table>
    <br />

    <div class="text-center">
        <hr />

        <p>
            Generated by SRMSS Reporting Module
        </p>

        <p>
            © 2026 Smart Route Management System
        </p>
    </div>
    </div>