@model IEnumerable<SRMSS.Models.Schedule>

@{
    Layout = null;
}

<style>
    body {
        font-family: Arial;
        margin: 20px;
        font-size: 12px;
    }

    h1, h2, h3, p {
        text-align: center;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    th {
        background-color: #0d6efd;
        color: white;
        padding: 8px;
        text-align: center;
    }

    td {
        border: 1px solid #ddd;
        padding: 6px;
        text-align: center;
    }

    .footer {
        text-align: center;
        margin-top: 20px;
    }
</style>

<div class="mb-3">
    <a asp-action="Index" class="btn btn-secondary"> ← Back </a>

    <a asp-action="ScheduleReportPDF" class="btn btn-danger">
        Download PDF
    </a>

</div>

<div class="text-center mb-4">
    <h1 style="color:#0d6efd;"> SMART ROUTE MANAGEMENT SYSTEM </h1>

    <h3>
        Schedule Management Report
    </h3>

    <p>
        Generated Date :
        @DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")
    </p>

    <hr />

</div>

<div> Total Schedules : <strong>@Model.Count()</strong> </div>

<br />

<table>
    <thead> <tr> <th>Schedule ID</th> <th>Route Code</th> <th>Bus Number</th> <th>Driver Name</th> <th>Schedule Date</th> <th>Departure Time</th> <th>Arrival Time</th> <th>Trip Type</th> <th>Trip Status</th> <th>Remarks</th> </tr> </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ScheduleID</td>
                <td>@item.RouteCode</td>
                <td>@item.BusNumber</td>
                <td>@item.DriverName</td>
                <td>@item.ScheduleDate.ToString("dd/MM/yyyy")</td>
                <td>@item.DepartureTime</td>
                <td>@item.ArrivalTime</td>
                <td>@item.TripType</td>
                <td>@item.TripStatus</td>
                <td>@item.Remarks</td>
            </tr>
        }
    </tbody>

</table>

<div class="footer">
    <hr />

    <p>
        Generated by SRMSS Reporting Module
    </p>

    <p>
        © 2026 Smart Route Management System
    </p>

</div>