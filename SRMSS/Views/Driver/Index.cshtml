@model IEnumerable<SRMSS.Models.Driver>

@{
    ViewData["Title"] = "Driver Management";
}

<div class="container mt-4">

    <h2 class="text-center">Driver Management</h2>

    <hr />

    <form method="get">
        <div class="row mb-3">

            <div class="col-md-4">
                <input type="text"
                       name="search"
                       class="form-control"
                       placeholder="Search Driver..." />
            </div>

            <div class="col-md-2">
                <button type="submit"
                        class="btn btn-primary">
                    Search
                </button>
            </div>

        </div>
    </form>

    <a href="/Driver/Create"
       class="btn btn-primary mb-3">
        Add New Driver
    </a>
    <div class="mt-3">

        
    <table class="table table-bordered table-striped">

        <thead>
            <tr>
                <th>Name</th>
                <th>License No</th>
                <th>Phone</th>
                <th>Date Of Birth</th>
                <th>License Expiry</th>
                <th>Assigned Route</th>
                <th>Working Hours</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.DriverName</td>
                    <td>@item.LicenseNumber</td>
                    <td>@item.PhoneNumber</td>
                    <td>@item.DateofBirth</td>
                    <td>@item.LicenseExpiryDate</td>
                    <td>@item.AssignedRoute</td>
                    <td>@item.WorkingHours</td>
                    <td>@item.Status</td>

                    <td>
                        <a href="/Driver/Edit/@item.DriverID"
                           class="btn btn-warning btn-sm">
                            Edit
                        </a>
                    <a href="/Driver/Delete/@item.DriverID"
                       class="btn btn-danger btn-sm"
                       onclick="return confirm('Are you sure want to delete this driver?');">
                        Delete
                    </a>
                    </td>

                </tr>
            }
                
        </tbody>

    </table>
        @for (int i = 1; i <= ViewBag.TotalPages; i++)
        {
            <a href="/Driver?page=@i"
               class="btn btn-primary btn-sm">
                @i
            </a>
        }

    </div>

</div>