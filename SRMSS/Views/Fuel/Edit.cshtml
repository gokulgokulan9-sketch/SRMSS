@model SRMSS.Models.FuelLog

<h3>Edit Fuel Log</h3>

<form asp-action="Edit">
    <input type="hidden" asp-for="FuelLogID" />

    <div class="mb-2">
        <label>Bus Number</label>
        <input asp-for="BusNumber" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Route Code</label>
        <input asp-for="RouteCode" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Fuel Date</label>
        <input asp-for="FuelDate" class="form-control" type="date" />
    </div>

    <div class="mb-2">
        <label>Fuel Quantity</label>
        <input asp-for="FuelQuantity" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Fuel Cost</label>
        <input asp-for="FuelCost" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Odometer Reading</label>
        <input asp-for="OdometerReading" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Fuel Station</label>
        <input asp-for="FuelStation" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Recorded By</label>
        <input asp-for="RecordedBy" class="form-control" />
    </div>

    <div class="mb-2">
        <label>Remarks</label>
        <input asp-for="Remarks" class="form-control" />
    </div>

    <button class="btn btn-success">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back</a>

</form>